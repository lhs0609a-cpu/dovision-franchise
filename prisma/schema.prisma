generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Inquiry {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String?
  region        String
  budget        String?
  experience    String?
  message       String?
  status        InquiryStatus @default(NEW)
  adminNote     String?
  privacyAgreed Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  franchisee    Franchisee?
}

// ============================================================
// 가맹점 개업 여정 (Franchisee Onboarding)
// ============================================================

model Franchisee {
  id                        String               @id @default(cuid())
  // 로그인
  email                     String               @unique
  password                  String
  // 기본 정보
  name                      String
  phone                     String
  centerName                String?              // 개업 센터명 (미정 시 null)
  region                    String               // 예: 경기 성남시 분당구
  address                   String?              // 확정된 임대차 주소
  // 연결: 문의 → 계약 전환 시
  inquiryId                 String?              @unique
  inquiry                   Inquiry?             @relation(fields: [inquiryId], references: [id])
  // 타임라인
  targetOpenDate            DateTime?            // 개업 희망일 (D-Day 기준점)
  contractSignedAt          DateTime?            // 가맹계약 체결일
  infoDisclosureReceivedAt  DateTime?            // 정보공개서 수령일 (법정 14일 숙고기간 기산)
  openedAt                  DateTime?            // 실제 개업일
  // 현재 단계 (캐시)
  currentPhase              Int                  @default(0)
  status                    FranchiseeStatus     @default(ONBOARDING)
  // 메타
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  progress                  ChecklistProgress[]
  documents                 FranchiseeDocument[]
  contractSignatures        ContractSignature[]
}

enum FranchiseeStatus {
  ONBOARDING   // 개업 준비 중
  OPERATING    // 운영 중
  SUSPENDED    // 휴업
  TERMINATED   // 해지
}

// 체크리스트 마스터 템플릿 (seed로 생성)
model ChecklistTemplate {
  id                 String              @id @default(cuid())
  phase              Int                 // 0 ~ 12
  order              Int                 // phase 내 순서
  title              String
  description        String?             // 세부 설명·주의사항
  isLegalRequired    Boolean             @default(false) // 법정 필수 항목 여부
  defaultOffsetDays  Int?                // D-Day 대비 권장 시점 (음수: 개업 전, 양수: 개업 후)
  progress           ChecklistProgress[]

  @@unique([phase, order])
}

// 가맹점주별 체크 진행 상태
model ChecklistProgress {
  id                String             @id @default(cuid())
  franchiseeId      String
  franchisee        Franchisee         @relation(fields: [franchiseeId], references: [id], onDelete: Cascade)
  templateId        String
  template          ChecklistTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  isChecked         Boolean            @default(false)
  checkedAt         DateTime?
  adminVerifiedAt   DateTime?          // 본사가 확인·승인한 시점
  note              String?            // 가맹점주 또는 본사 메모
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([franchiseeId, templateId])
}

// 가맹점주가 본사에 제출한 문서 (사업자등록증, 임대차계약서 등)
model FranchiseeDocument {
  id            String      @id @default(cuid())
  franchiseeId  String
  franchisee    Franchisee  @relation(fields: [franchiseeId], references: [id], onDelete: Cascade)
  category      String      // 예: "사업자등록증", "임대차계약서"
  fileName      String
  fileUrl       String      // 저장 경로 (S3 or 로컬)
  uploadedAt    DateTime    @default(now())
}

// ============================================================
// 가맹계약서 템플릿 (본사 관리)
// ============================================================

model ContractTemplate {
  id             String   @id @default(cuid())
  version        String   @unique              // "v2026.04.21"
  title          String                        // "두비전 가맹계약서"
  hwpFileUrl     String                        // Vercel Blob URL
  hwpFileName    String                        // 원본 파일명
  hwpFileSize    Int                           // bytes
  isActive       Boolean  @default(false)      // 현재 사용 중인 버전 (단일)
  effectiveFrom  DateTime?                     // 적용 시작일
  note           String?                       // 개정 사유 메모
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  signatures     ContractSignature[]
}

// 가맹점주별 계약서 열람·동의 기록
model ContractSignature {
  id              String            @id @default(cuid())
  franchiseeId    String
  franchisee      Franchisee        @relation(fields: [franchiseeId], references: [id], onDelete: Cascade)
  templateId      String
  template        ContractTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  viewedAt        DateTime?                  // 최초 열람 시각
  downloadedAt    DateTime?                  // HWP 다운로드 시각
  agreedAt        DateTime?                  // "읽고 동의" 체크 시각
  agreementIp     String?                    // 동의 당시 IP (감사 로그)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([franchiseeId, templateId])
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONSULTING
  VISITED
  CONTRACTED
  REJECTED
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Testimonial {
  id          String   @id @default(cuid())
  studentName String
  grade       String
  duration    String
  content     String
  achievement String
  imageUrl    String?
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String   @default("general")
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
