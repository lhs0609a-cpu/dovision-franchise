# ============================================================
# Environment Variables Example (복사 → .env.local로 저장 후 값 채우기)
# ============================================================
# .env.local 은 gitignore 됨. 실제 키는 절대 commit 금지.
# ============================================================

# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/dovision_franchise"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-hex-32"

# Admin
ADMIN_EMAIL="admin@dovision.kr"

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
NOTIFICATION_EMAIL="admin@dovision.kr"

# Site URL (production: https://dovision.kr)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================================
# AI 상권분석 (territory-analysis)
# ============================================================
# Google Maps JavaScript API Key (Cloud Console에서 HTTP referer 제한 필수)
#   발급: https://console.cloud.google.com/google/maps-apis
#   필요 API: Maps JavaScript API, Geocoding API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Kakao REST API Key (서버 전용)
#   발급: https://developers.kakao.com/console/app
#   필요 권한: 로컬(Local) 카테고리/키워드 검색
KAKAO_REST_API_KEY=""
