# ============================================================
# Environment Variables Example (복사 → .env.local로 저장 후 값 채우기)
# ============================================================
# .env.local 은 gitignore 됨. 실제 키는 절대 commit 금지.
# ============================================================

# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/dovision_franchise"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-hex-32"

# Admin
ADMIN_EMAIL="admin@dovision.kr"

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
NOTIFICATION_EMAIL="admin@dovision.kr"

# Site URL (production: https://dovision.kr)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================================
# AI 상권분석 (territory-analysis)
# ============================================================
# Kakao REST API Key (서버 전용 - 장소 검색)
#   발급: https://developers.kakao.com/console/app → 앱 키 → REST API 키
#   필요 권한: 로컬(Local) 카테고리/키워드 검색
KAKAO_REST_API_KEY=""

# Kakao JavaScript Key (클라이언트 지도 렌더링 전용)
#   같은 앱의 "JavaScript 키"를 사용 (REST 키와 다름)
#   플랫폼 > Web에 사이트 도메인 반드시 등록 (http://localhost:3000, https://dovision.kr 등)
NEXT_PUBLIC_KAKAO_JS_KEY=""

# ============================================================
# Vercel Blob (가맹계약서 HWP 파일 저장)
# ============================================================
# Vercel 대시보드 → Storage → Create Blob Store → 프로젝트 연결 시 자동 주입
# 로컬 개발 시에는 Vercel CLI로 당겨와야 함:
#   npx vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=""
